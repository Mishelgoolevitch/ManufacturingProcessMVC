<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Manufacturing System</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    
    <style>
            .sidebar {
                min-height: 100vh;
                background: linear-gradient(180deg, #2c3e50 0%, #3498db 100%);
            }

            .process-card {
                transition: transform 0.3s;
            }

                .process-card:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
                }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 d-md-block sidebar text-white p-4">
                <div class="position-sticky">
                    <h2 class="mb-4">
                        <i class="bi-gear-fill"></i> Manufacturing
                    </h2>
                    <ul class="nav flex-column">
                        <li class="nav-item mb-2">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                                <i class="bi-house"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item mb-2">
                            <a class="nav-link text-white" asp-controller="Process" asp-action="Index">
                                <i class="bi-list-task"></i> Processes
                            </a>
                        </li>
                        <li class="nav-item mb-2">
                            <a class="nav-link text-white" asp-controller="Drill" asp-action="Index">
                                <i class="bi-tools"></i> Drills
                            </a>
                        </li>
                        <li class="nav-item mb-2">
                            <a class="nav-link text-white" asp-controller="Tap" asp-action="Index">
                                <i class="bi-nut"></i> Taps
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                <span style="color: hsl(var(--primary)); font-weight: 500;"></span>
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <span style="color: hsl(var(--primary)); font-weight: 500;"></span>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
